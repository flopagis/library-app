<%
function buildQuery(overrides) {
  const params = Object.assign({ type: currentType, q: currentQuery, category: currentCategory }, overrides);
  const parts = [];
  if (params.type) parts.push('type=' + encodeURIComponent(params.type));
  if (params.q) parts.push('q=' + encodeURIComponent(params.q));
  if (params.category) parts.push('category=' + encodeURIComponent(params.category));
  return parts.length ? '/?' + parts.join('&') : '/';
}
%>
<%- include('partials/header', { title: 'The Library' }) %>

<h1>The Library</h1>
<p class="subtitle">Books and games available to borrow. Click one to request it.</p>

<div class="search-wrap">
  <form action="/" method="GET" class="search-form">
    <input type="search" name="q" id="search-input" value="<%= currentQuery %>" placeholder="Search titles&hellip;" autocomplete="off" />
    <% if (currentType) { %><input type="hidden" name="type" value="<%= currentType %>" /><% } %>
    <% if (currentCategory) { %><input type="hidden" name="category" value="<%= currentCategory %>" /><% } %>
    <button type="submit">Search</button>
  </form>
  <div id="search-suggestions" class="search-suggestions" hidden></div>
</div>

<script>
(function () {
  var ITEMS = <%- JSON.stringify(allTitles) %>;
  var input = document.getElementById('search-input');
  var box = document.getElementById('search-suggestions');

  function escapeHtml(s) {
    return s.replace(/[&<>"]/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
    });
  }

  function render() {
    var q = input.value.trim().toLowerCase();
    if (!q) { box.hidden = true; box.innerHTML = ''; return; }
    var matches = ITEMS.filter(function (item) {
      return item.title.toLowerCase().indexOf(q) !== -1;
    }).slice(0, 8);
    if (matches.length === 0) { box.hidden = true; box.innerHTML = ''; return; }
    box.innerHTML = matches.map(function (item) {
      return '<a href="/items/' + item.id + '">' + escapeHtml(item.title) + '</a>';
    }).join('');
    box.hidden = false;
  }

  input.addEventListener('input', render);
  input.addEventListener('focus', render);
  document.addEventListener('click', function (e) {
    if (e.target !== input && !box.contains(e.target)) box.hidden = true;
  });
})();
</script>

<div class="filter-bar">
  <a href="<%= buildQuery({ type: null, category: null }) %>" class="<%= !currentType ? 'active' : '' %>">All</a>
  <% Object.keys(ITEM_TYPES).forEach(function(t) { %>
    <a href="<%= buildQuery({ type: t, category: null }) %>" class="<%= currentType === t ? 'active' : '' %>"><%= ITEM_TYPES[t].label %>s</a>
  <% }); %>
</div>

<% if (availableCategories.length > 0) { %>
  <div class="filter-bar filter-bar-secondary">
    <a href="<%= buildQuery({ category: null }) %>" class="<%= !currentCategory ? 'active' : '' %>">All categories</a>
    <% availableCategories.forEach(function(c) { %>
      <a href="<%= buildQuery({ category: c }) %>" class="<%= currentCategory === c ? 'active' : '' %>"><%= c %></a>
    <% }); %>
  </div>
<% } %>

<% if (items.length === 0) { %>
  <p><%= currentQuery || currentType || currentCategory ? 'No items match your search.' : 'Nothing here yet.' %></p>
<% } %>

<div class="item-grid" id="item-grid">
  <%- include('partials/item-cards', { items: items, ITEM_TYPES: ITEM_TYPES, coverUrlForSize: coverUrlForSize }) %>
</div>

<div id="load-more-trigger" data-offset="<%= items.length %>" data-has-more="<%= hasMore ? '1' : '0' %>"></div>
<div id="load-more-spinner" class="load-more-spinner" hidden><div class="cover-spinner" style="position: static;"></div></div>

<script>
(function () {
  var trigger = document.getElementById('load-more-trigger');
  var spinner = document.getElementById('load-more-spinner');
  var grid = document.getElementById('item-grid');
  var loading = false;

  function loadMore() {
    if (loading || trigger.dataset.hasMore !== '1') return;
    loading = true;
    spinner.hidden = false;

    var params = new URLSearchParams(window.location.search);
    params.set('offset', trigger.dataset.offset);

    fetch('/items-page?' + params.toString())
      .then(function (res) {
        return res.text().then(function (html) {
          return { html: html, hasMore: res.headers.get('X-Has-More') === 'true', nextOffset: res.headers.get('X-Next-Offset') };
        });
      })
      .then(function (data) {
        grid.insertAdjacentHTML('beforeend', data.html);
        trigger.dataset.offset = data.nextOffset;
        trigger.dataset.hasMore = data.hasMore ? '1' : '0';
        loading = false;
        spinner.hidden = true;
        if (!data.hasMore) observer.disconnect();
      })
      .catch(function () { loading = false; spinner.hidden = true; });
  }

  var observer;
  if (trigger.dataset.hasMore === '1' && 'IntersectionObserver' in window) {
    observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) { if (entry.isIntersecting) loadMore(); });
    }, { rootMargin: '600px' });
    observer.observe(trigger);
  }
})();
</script>

<%- include('partials/footer') %>
