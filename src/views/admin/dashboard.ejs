<%- include('../partials/header', { title: 'Admin dashboard' }) %>

<h1>Admin dashboard</h1>

<section>
  <h2>Pending requests</h2>
  <% if (pendingRequests.length === 0) { %>
    <p class="muted">No pending requests.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Item</th><th>Requested by</th><th>Requested on</th><th>Due back</th><th></th></tr></thead>
      <tbody>
        <% pendingRequests.forEach(function(r) { %>
          <tr>
            <td><a class="button button-small" href="/items/<%= r.item.id %>"><%= r.item.title %></a></td>
            <td><%= r.requesterName %></td>
            <td><%= r.requestedAt.toDateString() %></td>
            <td>
              <form action="/admin/requests/<%= r.id %>/approve" method="POST" class="inline-form approve-form">
                <label class="checkbox-label">
                  <input type="checkbox" name="indefinite" checked
                         onchange="this.closest('.approve-form').querySelector('input[type=date]').disabled = this.checked" />
                  No due date
                </label>
                <input type="date" name="dueBack" value="<%= defaultDueBack %>" disabled />
                <button type="submit" class="btn-approve">Approve</button>
              </form>
            </td>
            <td>
              <form action="/admin/requests/<%= r.id %>/reject" method="POST" class="inline-form">
                <button type="submit" class="btn-reject">Reject</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<section>
  <h2>Currently out</h2>
  <% if (activeLoans.length === 0) { %>
    <p class="muted">Nothing out on loan right now.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Item</th><th>Borrower</th><th>Rented on</th><th>Due back</th><th></th></tr></thead>
      <tbody>
        <% activeLoans.forEach(function(l) { %>
          <tr class="<%= l.dueBack && l.dueBack < now ? 'row-overdue' : '' %>">
            <td><a class="button button-small" href="/items/<%= l.item.id %>"><%= l.item.title %></a></td>
            <td><%= l.borrowerName %></td>
            <td><%= l.rentedOn.toDateString() %></td>
            <td><%= l.dueBack ? l.dueBack.toDateString() : '—' %></td>
            <td>
              <form action="/admin/loans/<%= l.id %>/return" method="POST" class="inline-form">
                <button type="submit">Mark returned</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<section>
  <div class="section-header">
    <h2>All items</h2>
    <a class="button" href="/admin/items/new">+ Add item</a>
  </div>
  <div class="search-wrap">
    <form action="/admin" method="GET" class="search-form">
      <input type="search" name="q" id="admin-search-input" value="<%= currentQuery %>" placeholder="Search titles&hellip;" autocomplete="off" />
      <button type="submit">Search</button>
    </form>
    <div id="admin-search-suggestions" class="search-suggestions" hidden></div>
  </div>

  <script>
  (function () {
    var ITEMS = <%- JSON.stringify(allTitles) %>;
    var input = document.getElementById('admin-search-input');
    var box = document.getElementById('admin-search-suggestions');

    function escapeHtml(s) {
      return s.replace(/[&<>"]/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
      });
    }

    function render() {
      var q = input.value.trim().toLowerCase();
      if (!q) { box.hidden = true; box.innerHTML = ''; return; }
      var matches = ITEMS.filter(function (item) {
        return item.title.toLowerCase().indexOf(q) !== -1;
      }).slice(0, 8);
      if (matches.length === 0) { box.hidden = true; box.innerHTML = ''; return; }
      box.innerHTML = matches.map(function (item) {
        return '<a href="/admin/items/' + item.id + '/edit">' + escapeHtml(item.title) + '</a>';
      }).join('');
      box.hidden = false;
    }

    input.addEventListener('input', render);
    input.addEventListener('focus', render);
    document.addEventListener('click', function (e) {
      if (e.target !== input && !box.contains(e.target)) box.hidden = true;
    });
  })();
  </script>
  <% if (items.length === 0) { %>
    <p class="muted"><%= currentQuery ? 'No items match your search.' : 'No items yet.' %></p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th></th><th>Title</th><th>Type</th><th>Category</th><th>Status</th><th></th><th></th></tr></thead>
    <tbody>
      <% items.forEach(function(item) { %>
        <tr>
          <td class="admin-cover-cell">
            <% if (item.coverUrl) { %>
              <img class="admin-cover-thumb" src="<%= coverUrlForSize(item.coverUrl, 'S') %>" alt="" />
            <% } else { %>
              <div class="admin-cover-thumb admin-cover-placeholder"><%= ITEM_TYPES[item.type].emoji %></div>
            <% } %>
          </td>
          <td><a class="button button-small" href="/items/<%= item.id %>"><%= item.title %></a></td>
          <td><%= ITEM_TYPES[item.type].label %></td>
          <td><%= item.category || '—' %></td>
          <td>
            <span class="badge badge-<%= item.status.state.toLowerCase() %>">
              <% if (item.status.state === 'AVAILABLE') { %>In Library
              <% } else if (item.status.state === 'REQUESTED') { %>Requested
              <% } else { %>Rented<% } %>
            </span>
          </td>
          <td><a class="button button-small" href="/admin/items/<%= item.id %>/edit">Edit</a></td>
          <td>
            <form action="/admin/items/<%= item.id %>/delete" method="POST" class="inline-form"
                  onsubmit="return confirm('Delete this item?');">
              <button type="submit" class="btn-reject" <%= item.status.state !== 'AVAILABLE' ? 'disabled title=\"Item is requested or out on loan\"' : '' %>>Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</section>

<%- include('../partials/footer') %>
