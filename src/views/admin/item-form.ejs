<%- include('../partials/header', { title: item ? 'Edit item' : 'Add item' }) %>

<a class="back-link" href="/admin">&larr; Back to dashboard</a>

<h1><%= item ? 'Edit item' : 'Add item' %></h1>

<form action="<%= item ? '/admin/items/' + item.id + '/edit' : '/admin/items/new' %>" method="POST" class="admin-form">
  <label for="title">Title</label>
  <input type="text" id="title" name="title" required maxlength="200" value="<%= item ? item.title : '' %>" />

  <label for="type">Type</label>
  <select id="type" name="type">
    <% Object.keys(ITEM_TYPES).forEach(function(t) { %>
      <option value="<%= t %>" <%= item && item.type === t ? 'selected' : '' %>><%= ITEM_TYPES[t].label %></option>
    <% }); %>
  </select>

  <label for="author">Author (optional)</label>
  <input type="text" id="author" name="author" maxlength="200" value="<%= item && item.author ? item.author : '' %>" />

  <label for="category">Category (optional)</label>
  <input type="text" id="category" name="category" list="category-suggestions" maxlength="60"
         placeholder="e.g. Sci-Fi, Strategy" value="<%= item && item.category ? item.category : '' %>" />
  <datalist id="category-suggestions">
    <% existingCategories.forEach(function(c) { %><option value="<%= c %>"></option><% }); %>
  </datalist>

  <label for="externalUrl">Goodreads / BoardGameGeek link (optional)</label>
  <input type="url" id="externalUrl" name="externalUrl" placeholder="https://..." value="<%= item && item.externalUrl ? item.externalUrl : '' %>" />

  <label for="coverUrl">Cover image URL (optional)</label>
  <input type="url" id="coverUrl" name="coverUrl" value="<%= item && item.coverUrl ? item.coverUrl : '' %>" />

  <label for="notes">Notes (optional)</label>
  <textarea id="notes" name="notes" rows="3"><%= item && item.notes ? item.notes : '' %></textarea>

  <button type="submit"><%= item ? 'Save changes' : 'Add item' %></button>
</form>

<%- include('../partials/footer') %>
