<%- include('../partials/header', { title: 'Admin dashboard' }) %>

<h1>Admin dashboard</h1>

<section>
  <h2>Pending requests</h2>
  <% if (pendingRequests.length === 0) { %>
    <p class="muted">No pending requests.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Item</th><th>Requested by</th><th>Requested on</th><th>Due back</th><th></th></tr></thead>
      <tbody>
        <% pendingRequests.forEach(function(r) { %>
          <tr>
            <td><a href="/items/<%= r.item.id %>"><%= r.item.title %></a></td>
            <td><%= r.requesterName %></td>
            <td><%= r.requestedAt.toDateString() %></td>
            <td>
              <form action="/admin/requests/<%= r.id %>/approve" method="POST" class="inline-form approve-form">
                <label class="checkbox-label">
                  <input type="checkbox" name="indefinite" checked
                         onchange="this.closest('.approve-form').querySelector('input[type=date]').disabled = this.checked" />
                  No due date
                </label>
                <input type="date" name="dueBack" value="<%= defaultDueBack %>" disabled />
                <button type="submit" class="btn-approve">Approve</button>
              </form>
            </td>
            <td>
              <form action="/admin/requests/<%= r.id %>/reject" method="POST" class="inline-form">
                <button type="submit" class="btn-reject">Reject</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<section>
  <h2>Currently out</h2>
  <% if (activeLoans.length === 0) { %>
    <p class="muted">Nothing out on loan right now.</p>
  <% } else { %>
    <table class="admin-table">
      <thead><tr><th>Item</th><th>Borrower</th><th>Rented on</th><th>Due back</th><th></th></tr></thead>
      <tbody>
        <% activeLoans.forEach(function(l) { %>
          <tr class="<%= l.dueBack && l.dueBack < now ? 'row-overdue' : '' %>">
            <td><a href="/items/<%= l.item.id %>"><%= l.item.title %></a></td>
            <td><%= l.borrowerName %></td>
            <td><%= l.rentedOn.toDateString() %></td>
            <td><%= l.dueBack ? l.dueBack.toDateString() : '—' %></td>
            <td>
              <form action="/admin/loans/<%= l.id %>/return" method="POST" class="inline-form">
                <button type="submit">Mark returned</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<section>
  <div class="section-header">
    <h2>All items</h2>
    <a class="button" href="/admin/items/new">+ Add item</a>
  </div>
  <form action="/admin" method="GET" class="search-form">
    <input type="search" name="q" value="<%= currentQuery %>" placeholder="Search titles&hellip;" />
    <button type="submit">Search</button>
  </form>
  <% if (items.length === 0) { %>
    <p class="muted"><%= currentQuery ? 'No items match your search.' : 'No items yet.' %></p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Title</th><th>Type</th><th>Category</th><th>Status</th><th></th><th></th></tr></thead>
    <tbody>
      <% items.forEach(function(item) { %>
        <tr>
          <td><a href="/items/<%= item.id %>"><%= item.title %></a></td>
          <td><%= ITEM_TYPES[item.type].label %></td>
          <td><%= item.category || '—' %></td>
          <td>
            <span class="badge badge-<%= item.status.state.toLowerCase() %>">
              <% if (item.status.state === 'AVAILABLE') { %>In Library
              <% } else if (item.status.state === 'REQUESTED') { %>Requested
              <% } else { %>Rented<% } %>
            </span>
          </td>
          <td><a href="/admin/items/<%= item.id %>/edit">Edit</a></td>
          <td>
            <form action="/admin/items/<%= item.id %>/delete" method="POST" class="inline-form"
                  onsubmit="return confirm('Delete this item?');">
              <button type="submit" class="btn-reject" <%= item.status.state !== 'AVAILABLE' ? 'disabled title=\"Item is requested or out on loan\"' : '' %>>Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</section>

<%- include('../partials/footer') %>
